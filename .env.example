# Kaplan Solutions — lokale Konfiguration (nicht committen!)
# Kopieren: cp .env.example .env

# E-Mail (von Render übernehmen)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=Kaplan Solutions <kontakt@kaplan-solutions.de>
REPLY_EMAIL=kontakt@kaplan-solutions.de
ADMIN_EMAIL=Kawa.f.Kaplan@gmail.com

# Google Places — Firmen finden (Google Cloud Console → Places API)
GOOGLE_PLACES_API_KEY=AIzaSyxxxxxxxx

# Firmendaten (optional, für Signatur)
COMPANY_OPERATOR=
COMPANY_STREET=Hochstraße 8
COMPANY_ZIP=13357
COMPANY_CITY=Berlin
COMPANY_PHONE=+49 159 01309199
COMPANY_WEBSITE=https://kaplan-solutions.de

# Outreach-Limits (optional)
OUTREACH_DAILY_LIMIT=80
OUTREACH_DISCOVER_LIMIT=200
OUTREACH_ENRICH_BATCH=30
OUTREACH_SEND_BATCH=8
OUTREACH_DISCOVER_BATCH=3
OUTREACH_INTERVAL=300
OUTREACH_REPORT_EMAIL=Kawa.f.Kaplan@gmail.com
OUTREACH_REPORT_HOUR=18

# Städte-Fokus (Komma-getrennt). Berlin-Region + Metropolen = schnelles Portfolio.
# Leer lassen = deutschlandweit.
OUTREACH_FOCUS_CITIES=Berlin,Potsdam,Cottbus,Brandenburg an der Havel,Hamburg,München,Köln,Frankfurt am Main,Leipzig,Dresden,Hannover,Düsseldorf,Stuttgart,Nürnberg,Bremen,Bonn,Münster,Karlsruhe,Magdeburg,Rostock,Kiel,Wiesbaden

# Lead-Follow-up: automatische Antwort am Folgetag (Europe/Berlin)
LEAD_FOLLOWUP_HOUR=8
LEAD_DIGEST_HOUR=9
LEAD_DIGEST_FALLBACK_HOUR=10
LEAD_DIGEST_GRACE_MINUTES=15
LEAD_DIGEST_EMAIL=Kawa.f.Kaplan@gmail.com
LEAD_AGENT_NAME=Kaplan Solutions · Partnervermittlung
LEAD_FOLLOWUP_RETRIES=3

# Google Sheets Matching (Apps Script Webhook-URL mit /exec)
# SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/XXXX/exec
MATCH_RESCAN_INTERVAL=3600
MATCH_BRIEFING_HOUR=10
MATCH_BRIEFING_EMAIL=Kawa.f.Kaplan@gmail.com
# Sofort-Alert bei Match >= 75% (Admin + Bauherr)
MATCH_ALERT_MIN_SCORE=75
# Gleicher Wert in Google Sheet _Meta B6 eintragen
MATCH_ALERT_SECRET=
# Optional: Secret für Cron-Endpoint /api/cron/lead-followups
CRON_SECRET=


# Provisionsmodell (AGB / Vermittlungsvertrag)
PROVISION_PARTNER_PERCENT=5.0
PROVISION_PARTNER_MIN_EUR=1500
PROVISION_PARTNER_MAX_EUR=35000
PROVISION_PARTNER_FOLLOWUP_MONTHS=12
PROVISION_BAUHERR_PERCENT=0
PROVISION_BAUHERR_MIN_EUR=0
PROVISION_BERATUNG_EUR=0
